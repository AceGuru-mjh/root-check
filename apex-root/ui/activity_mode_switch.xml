<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="#FF1A1A2E">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="APEX-Root Control"
        android:textColor="#FFE94560"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mode: Detection\nActive: NO"
        android:textColor="#FFEEEEEE"
        android:textSize="14sp"
        android:padding="16dp"
        android:background="#FF16213E"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_detect"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🔍 Detection Mode (No Hide)"
        android:backgroundTint="#FF0F3460"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_hide"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🛡 Hide Mode (Unidirectional)"
        android:backgroundTint="#FFE94560"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_game"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🎮 Game Mode (Aggressive)"
        android:backgroundTint="#FF533483"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="APEX-Root sees real Root status\nAll other apps see clean system"
        android:textColor="#FF888888"
        android:textSize="12sp"
        android:gravity="center" />
</LinearLayout>
