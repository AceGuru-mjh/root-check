type apex_firewall, domain;
type apex_firewall_exec, exec_type, file_type, vendor_file_type;

# APEX-Root domain transition
init_daemon_domain(apex_firewall)

# Allow access to eBPF sysfs
allow apex_firewall apex_firewall:capability { sys_admin sys_rawio };

# Allow bpf() syscall
allow apex_firewall self:bpf { prog_load prog_run map_create map_read map_write };

# Access to /sys/fs/bpf
allow apex_firewall sysfs_bpf:dir { read search };
allow apex_firewall sysfs_bpf:file { read write open };

# Tracepoint access
allow apex_firewall self:tracepoint { attach };

# Kernel access for bpf_probe_write_user
allow apex_firewall kernel:system { syslog_read };

# Hide mode: mount namespace isolation
allow apex_firewall self:capability { sys_admin sys_ptrace };

# Access /proc for other processes (self-hide)
allow apex_firewall self:process { ptrace };
allow apex_firewall proc:dir { read search };
allow apex_firewall proc_t:file { read open getattr };

# Communication with app domain
allow apex_firewall apex_app:unix_stream_socket { connectto sendto };
allow apex_firewall apex_app:fd use;

# Read baseline files
allow apex_firewall proc_version:file read;
allow apex_firewall proc_cmdline:file read;
allow apex_firewall system_build_prop:file read;
